# ─── FastSpring Configuration ───
# Get these from your FastSpring dashboard:
#   Settings → API Keys → Create API Key
#   Settings → Store → Store ID (your store front name)
#   Settings → Webhooks → Create Webhook (set URL to https://exploro-os.com/api/fastspring/webhook)

FASTSPRING_STORE_ID=your-store-id
FASTSPRING_API_KEY=your-api-key
FASTSPRING_WEBHOOK_SECRET=your-webhook-secret

# Product paths created in FastSpring dashboard:
#   Products → Create Product → Subscription
FASTSPRING_PRODUCT_SOLO=exploro-solo-monthly
FASTSPRING_PRODUCT_TEAM=exploro-team-monthly
